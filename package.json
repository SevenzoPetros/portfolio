{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://sevenzo-portfolio.com",
  "scripts": {
    "dev": "set NODE_OPTIONS=--max-old-space-size=4096 && next dev",
    "dev:clean": "set NODE_OPTIONS=--max-old-space-size=4096 && next dev --experimental-turbo",
    "build": "next build",
    "build:static": "next build && next export",
    "build:windows": "next build && electron-builder --win",
    "start": "next start",
    "start:windows": "electron .",
    "electron": "electron .",
    "electron-dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "build:all": "node scripts/build-all-platforms.js build",
    "deploy:all": "node scripts/build-all-platforms.js deploy",
    "package:windows": "node scripts/build-all-platforms.js package-windows"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "autoprefixer": "^10.4.27",
    "next": "^15.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^9",
    "eslint-config-next": "^15.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^7.2.0"
  },
  "main": "public/electron.js",
  "build": {
    "appId": "com.sevenzo.portfolio",
    "productName": "Sevenzo Portfolio",
    "directories": {
      "output": "dist-windows"
    },
    "files": [
      "out/**/*",
      "public/electron.js",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
